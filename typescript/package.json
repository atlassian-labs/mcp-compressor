{
  "name": "@atlassian/mcp-compressor",
  "version": "0.10.1",
  "description": "TypeScript MCP server wrapper for reducing tokens consumed by MCP tools.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/atlassian-labs/mcp-compressor",
  "bugs": {
    "url": "https://github.com/atlassian-labs/mcp-compressor/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atlassian-labs/mcp-compressor.git",
    "directory": "typescript"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bash": {
      "import": "./dist/bash_commands.js",
      "types": "./dist/bash_commands.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "bin": {
    "mcp-compressor": "dist/cli.js",
    "atlassian-mcp-compressor": "dist/cli.js"
  },
  "scripts": {
    "build": "bun run tsc -p tsconfig.build.json",
    "cli": "bun src/cli.ts",
    "dev": "bun run build && bun run dist/cli.js",
    "format": "oxfmt src/ tests/ '!**/node_modules/**' '!**/dist/**' '!**/coverage/**'",
    "format:check": "oxfmt --check src/ tests/ '!**/node_modules/**' '!**/dist/**' '!**/coverage/**'",
    "lint": "oxlint src/ tests/",
    "lint:fix": "oxlint --fix src/ tests/",
    "test": "vitest run",
    "typecheck": "bun run tsc --noEmit -p tsconfig.json",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test",
    "check:ci": "bun run lint && bun run format:check && bun run typecheck && vitest run --exclude tests/e2e.test.ts"
  },
  "publishConfig": {
    "registry": "https://packages.atlassian.com/api/npm/atlassian-npm/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@toon-format/toon": "^2.1.0",
    "commander": "^14.0.3",
    "fastmcp": "^4.0.0",
    "zod": "^4.1.13"
  },
  "peerDependencies": {
    "just-bash": "^2.14.0"
  },
  "peerDependenciesMeta": {
    "just-bash": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "just-bash": "^2.14.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
